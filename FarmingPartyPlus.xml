<GuiXml>
  <Controls>
    <TopLevelControl name="FarmingPartyPlusWindow" mouseEnabled="true" movable="true" clampedToScreen="true" hidden="true" resizeHandleSize="8">
      <OnUpdate>
        local w, h = self:GetDimensions()
        if ((self.currentWidth ~= w) or (self.currentHeight ~= h)) then
          self.currentWidth = w
          self.currentHeight = h
          if(self.onResize) then
            self.onResize()
          end
        end
      </OnUpdate>
      <DimensionConstraints minX="400" minY="80" />
      <OnMoveStart>FarmingPartyPlusSettings:MoveStart()</OnMoveStart>
      <OnMoveStop>FarmingPartyPlusSettings:MoveStop()</OnMoveStop>

      <Controls>
        <Backdrop name="$(parent)BG" inherits="ZO_DefaultBackdrop"/>
        <TextBuffer
          name="$(parent)Buffer"
          inheritAlpha="true"
          font="ZoFontGameSmall"
          linkEnabled="true"
          maxHistoryLines="200"/>
      </Controls>
    </TopLevelControl>
  </Controls>
</GuiXml>
