<GuiXml>
  <Controls>
    <TopLevelControl name="FarmingPartyPlusMemberItemsWindow" inherits="FarmingPartyPlusListWindow">
      <DimensionConstraints minX="430" minY="150" />
      <Controls>
        <Label name="$(parent)Title" font="ZoFontHeader3" height="25" inheritAlpha="true" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_NORMAL" verticalAlignment="TOP" horizontalAlignment="CENTER" text="Farming Party Plus Items">
          <Anchor point="TOP" relativeTo="$(parent)" relativePoint="TOP" offsetX="-10" offsetY="5" />
        </Label>
        <Control name="$(parent)Headers">
          <Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" offsetX="10" offsetY="51" />
          <Dimensions y="32" />
          <Controls>
            <Control name="$(parent)Item" mouseEnabled="true">
              <Anchor point="TOPLEFT" offsetX="15"/>
              <Dimensions x="220" y="32" />
              <Controls>
                <Label name="$(parent)Name" font="ZoFontGame" color="3689EF" modifyTextType="NONE" horizontalAlignment="LEFT" verticalAlignment="CENTER" text="Item">
                  <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
                  <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                </Label>
              </Controls>
            </Control>
            <Control name="$(parent)Count" mouseEnabled="true">
              <Anchor point="TOPLEFT" relativeTo="$(parent)Item" relativePoint="TOPRIGHT" offsetX="18" />
              <Anchor point="BOTTOMLEFT" relativeTo="$(parent)Item" relativePoint="BOTTOMRIGHT" offsetX="18" />
              <Dimensions x="72" y="32" />
              <Controls>
                <Label name="$(parent)Value" font="ZoFontGame" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_NORMAL" modifyTextType="NONE" horizontalAlignment="CENTER" verticalAlignment="CENTER" text="Count">
                  <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
                  <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                </Label>
              </Controls>
            </Control>
            <Control name="$(parent)TotalValue">
              <Anchor point="TOPLEFT" relativeTo="$(parent)Count" relativePoint="TOPRIGHT" offsetX="18" />
              <Dimensions x="128" y="32" />
              <Controls>
                <Label name="$(parent)TotalValue" font="ZoFontGame" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_NORMAL" modifyTextType="NONE" horizontalAlignment="CENTER" verticalAlignment="CENTER" text="Total Value">
                  <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
                  <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                </Label>
              </Controls>
            </Control>
          </Controls>
        </Control>
        <Control name="$(parent)List" inherits="ZO_ScrollList">
          <Anchor point="TOPLEFT" relativeTo="$(parent)Headers" relativePoint="BOTTOMLEFT" offsetX="0" offsetY="5"/>
          <Anchor point="BOTTOMRIGHT" relativeTo="$(parent)" relativePoint="BOTTOMRIGHT" offsetX="0" offsetY="-5"/>
        </Control>
      </Controls>
    </TopLevelControl>

    <Control name="FarmingPartyPlusItemDataRow" inherits="FarmingPartyPlusListRow" virtual="true">
      <Controls>
        <Label name="$(parent)Farmer" hidden="true" inheritAlpha="true" verticalAlignment="CENTER" horizontalAlignment="LEFT" wrapMode="ELLIPSIS" font="EsoUI/Common/Fonts/ProseAntiquePSMT.otf|15" text="Farmer">
          <Dimensions x="200" />
          <Anchor point="TOPLEFT" relativeTo="$(parent)" relativePoint="TOPLEFT" offsetX="15" offsetY="0"/>
        </Label>
        <Control name="$(parent)ItemName" inherits="FarmingPartyPlusItemColumn" inheritAlpha="true" mouseEnabled="true">
          <Dimensions x="220" />
          <Anchor point="TOPLEFT" relativeTo="$(parent)Farmer" relativePoint="TOPLEFT" offsetX="0" offsetY="0"/>
          <Anchor point="BOTTOMLEFT" relativeTo="$(parent)Farmer" relativePoint="BOTTOMLEFT" offsetX="0" offsetY="0"/>
        </Control>
        <Label name="$(parent)Count" inheritAlpha="true" verticalAlignment="CENTER" horizontalAlignment="CENTER" wrapMode="ELLIPSIS" font="EsoUI/Common/Fonts/ProseAntiquePSMT.otf|15">
          <Dimensions x="72" />
          <Anchor point="TOPLEFT" relativeTo="$(parent)ItemName" relativePoint="TOPRIGHT" offsetX="18" offsetY="0"/>
          <Anchor point="BOTTOMLEFT" relativeTo="$(parent)ItemName" relativePoint="BOTTOMRIGHT" offsetX="18" offsetY="0"/>
        </Label>
        <Label name="$(parent)TotalValue" inheritAlpha="true" verticalAlignment="CENTER" horizontalAlignment="CENTER" wrapMode="ELLIPSIS" font="EsoUI/Common/Fonts/ProseAntiquePSMT.otf|15">
          <Dimensions x="128" />
          <Anchor point="TOPLEFT" relativeTo="$(parent)Count" relativePoint="TOPRIGHT" offsetX="18" offsetY="0"/>
          <Anchor point="BOTTOMLEFT" relativeTo="$(parent)Count" relativePoint="BOTTOMRIGHT" offsetX="18" offsetY="0"/>
        </Label>
      </Controls>
    </Control>
  </Controls>
</GuiXml>
